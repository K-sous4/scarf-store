# Local development — safe defaults for ./dev (clone and run)
# Do not use these values in production.
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://scarf_user:scarf_password@localhost:5432/scarf_store_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Backend
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-this-in-production

# CORS — comma-separated origins allowed by the backend
ALLOWED_ORIGINS=http://localhost:3000

# Admin seed (created on first startup if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@scarfstore.com

# Frontend
NEXT_PUBLIC_API_URL=/api/v1
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Password reset (opcional — SMTP)
# PASSWORD_RESET_TTL_SECONDS=3600
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@scarfstore.com
# SMTP_USE_TLS=true
